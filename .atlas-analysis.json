  "keyFeatures": [
    "One-codebase cross-platform compilation to 8+ mini-program platforms and Web",
    "Supports both WeChat and Alipay mini-program DSL as source",
    "Plugin-based architecture with full lifecycle hooks",
    "Bundle and transform compile modes for different use cases",
    "Supports miniprogram, subpackage, and plugin compile types",
    "Runtime API normalization across platforms",
    "TypeScript, Less/SCSS, JSONC/JSON5 file support",
    "CSS class name compression experiments",
    "Module sharing and consuming between subpackages",
    "Built-in analyzer, mock server, and code generator"
  ],
  "publicApiSurface": [
